---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import SeriesCard from '../components/SeriesCard.astro';

const series = await getCollection('series');
---

<BaseLayout title="Series" description="Series and learning pathways">
	<section>
		<h1>Series</h1>
		<p class="muted">Longer learning pathways and ordered collections of posts.</p>
		<div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: var(--space-md);">
			{series.map(s => (
				<SeriesCard title={s.data.title} description={s.data.description} progress={0.3} href={`/series/${s.id}`} />
			))}
		</div>
	</section>
</BaseLayout>
