---
/**
 * FooterCTA.astro - call-to-action block used at bottom of pages
 */
interface Props { title?: string; body?: string; href?: string; ctaText?: string }
const { title = 'Want to collaborate?', body = 'I mentor, speak, and write about building reliable systems.', href = '/about', ctaText = 'Get in touch' } = Astro.props;
---

<section class="footer-cta" role="region" aria-label="Call to action">
	<div class="cta-inner">
		<h3>{title}</h3>
		<p>{body}</p>
		<a href={href} data-button="primary" class="cta-link">{ctaText}</a>
	</div>
</section>

<style>
	.footer-cta { background: linear-gradient(90deg, rgba(79,70,229,0.06), rgba(79,70,229,0.02)); padding: var(--space-lg); border-radius: var(--radius-md); border: 1px solid var(--color-border); }
	.cta-inner { max-width: var(--max-width-content); margin: 0 auto; text-align: center; }
	.cta-inner h3 { margin-bottom: var(--space-sm); }
	.cta-link { display: inline-block; margin-top: var(--space-md); }
</style>
