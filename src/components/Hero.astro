---
import avatarImage from '../assets/avatar_real.webp';
import { SITE_TITLE } from '../consts';

const title="Hi! I'm Marco" ;
const subtitle = "Full-Stack Software Engineer growing into architecture & distributed systems" ;
---

<section class="hero" data-hero>
	<div class="hero-inner">
		<div class="avatar-wrapper">
			<img src={avatarImage.src} alt={SITE_TITLE} class="avatar" />
		</div>
		<div class="hero-content">
		<h1>{title}</h1>
		{subtitle && <p class="hero-sub">{subtitle}</p>}
		<slot />
		</div>
	</div>
</section>

<style>
	[data-hero] {
		padding: var(--space-md) 0;
		text-align: left;
	}

	.hero {
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.hero-inner {
		max-width: var(--max-width-content);
		display: flex;
		align-items: center;
		gap: var(--space-lg);
	}

	.avatar-wrapper {
		flex-shrink: 0;
	}

	.avatar {
		width: 300px;
		height: 300px;
		border-radius: 50%;
		object-fit: cover;
		border: 4px solid var(--color-accent);
		display: block;
	}

	[data-hero] h1 {
		font-size: clamp(1.8rem, 4vw, var(--font-size-5xl));
		line-height: 1.05;
		margin-bottom: var(--space-md);
	}

	.hero-sub {
		color: var(--color-text-secondary);
		font-size: var(--font-size-lg);
		margin-bottom: var(--space-md);
	}

	.hero-focus {
		color: var(--color-text-secondary);
		font-size: var(--font-size-sm);
	}

	@media (max-width: 640px) {
		.hero-inner {
			flex-direction: column;
			text-align: center;
		}
	}
</style>
