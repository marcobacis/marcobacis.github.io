---
import { getCollection } from "astro:content";
import { SITE_TITLE, SOCIAL_LINKS } from "../consts";

const links = await getCollection("menu");
---

<footer data-footer>
	<div class="footer-container">
		<div class="footer-content">
			<div class="footer-section description">
				<h3>{SITE_TITLE}</h3>
				<p>
					Full-stack engineer. Growing into software architecture and
					distributed systems. Learning in public.
				</p>
			</div>

			<div class="footer-section navigation">
				<h4>Navigate</h4>
				<ul>
					{
						links.map((link) => (
							<li>
								<a href={link.data.path}>{link.data.label}</a>
							</li>
						))
					}
				</ul>
			</div>

			<div class="footer-section social-links">
				<h4>Connect</h4>
				<div class="social-links-footer">
					<a
						href={SOCIAL_LINKS.github}
						title="GitHub"
						aria-label="GitHub Profile"
					>
						<svg
							viewBox="0 0 24 24"
							aria-hidden="true"
							width="20"
							height="20"
							fill="currentColor"
						>
							<path
								d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v 3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
							></path>
						</svg>
						GitHub
					</a>
					<a
						href={SOCIAL_LINKS.linkedin}
						title="LinkedIn"
						aria-label="LinkedIn Profile"
					>
						<svg
							viewBox="0 0 24 24"
							aria-hidden="true"
							width="20"
							height="20"
							fill="currentColor"
						>
							<path
								d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"
							></path>
							<circle cx="4" cy="4" r="2"></circle>
						</svg>
						LinkedIn
					</a>
				</div>
			</div>
		</div>

		<div class="footer-bottom">
			<p>
				&copy; {new Date().getFullYear()}
				{SITE_TITLE}. All rights reserved.
			</p>
		</div>
	</div>
</footer>

<style>
	[data-footer] {
		background-color: var(--color-surface);
		border-top: 1px solid var(--color-border);
		margin-top: var(--space-lg);
	}

	.footer-container {
		max-width: var(--max-width-wide);
		margin: 0 auto;
		padding: var(--space-xl) var(--space-lg);
	}

	.footer-content {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
		gap: var(--space-xl);
		margin-bottom: var(--space-xl);
	}

	.footer-section h3 {
		font-size: var(--font-size-lg);
		margin-bottom: var(--space-md);
	}

	.footer-section h4 {
		font-size: var(--font-size-base);
		margin-bottom: var(--space-md);
	}

	.footer-section p {
		color: var(--color-text-secondary);
		margin-bottom: var(--space-md);
	}

	.footer-section ul {
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.footer-section li {
		margin-bottom: var(--space-sm);
	}

	.footer-section a {
		color: var(--color-text-secondary);
		transition: color var(--transition-fast);
	}

	.footer-section a:hover {
		color: var(--color-accent);
	}

	.social-links-footer {
		display: flex;
		flex-direction: column;
		gap: var(--space-sm);
	}

	.social-links-footer a {
		display: flex;
		align-items: center;
		gap: var(--space-sm);
		color: var(--color-text-secondary);
		text-decoration: none;
		transition: color var(--transition-fast);
		padding: var(--space-sm) 0;
	}

	.social-links-footer a:hover {
		color: var(--color-accent);
	}

	.social-links-footer svg {
		flex-shrink: 0;
	}

	.footer-bottom {
		padding-top: var(--space-lg);
		border-top: 1px solid var(--color-border);
		text-align: center;
		font-size: var(--font-size-sm);
		color: var(--color-text-secondary);
	}

	.footer-bottom p {
		margin-bottom: var(--space-sm);
	}

	.footer-bottom a {
		color: var(--color-text-secondary);
	}

	.footer-bottom a:hover {
		color: var(--color-accent);
	}

	/* Mobile styles */
	@media (max-width: 768px) {
		.footer-container {
			padding: var(--space-lg) var(--space-md);
		}

		.footer-content {
			grid-template-columns: 1fr;
			gap: var(--space-lg);
		}

		.navigation {
			text-align: center;
		}

		.social-links {
			text-align: center;
			a {
				justify-content: center;
			}
		}
	}
</style>
