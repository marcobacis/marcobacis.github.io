---
import type { InferEntrySchema } from 'astro:content';
import { getCollection } from 'astro:content';

interface Props { 
    percent: number;
    label?: string;
}
const { percent, label } = Astro.props;
---

<div class="progress-root" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow={percent}>
    <div class="progress-track">
        <div class="progress-thumb" style={`width: ${percent}%`} data-progress-thumb></div>
    </div>
    <span class="progress-label">{label || `${percent}%`}</span>
</div>

<style>
    .progress-root { 
        display: flex; 
        align-items: center;
        gap: var(--space-sm); 
    }

	.progress-track { 
        flex: 1; 
        height: 10px; 
        background: var(--color-muted-light); 
        border-radius: 999px; 
        overflow: hidden; 
        border: 1px solid var(--color-border); 
    }

	[data-progress-thumb] { 
        height: 100%;
        background: linear-gradient(90deg, var(--color-accent), var(--color-accent-hover)); 
        transition: width var(--transition-medium) ease; 
    }

	.progress-label { 
        font-size: var(--font-size-sm); 
        color: var(--color-text-secondary); 
        padding-left: var(--space-sm);
        text-align: right; 
    }
</style>