---
/**
 * Callout.astro - small callout box for tradeoffs / tips
 */
interface Props { tone?: 'note' | 'warning' | 'tip'; title?: string }
const { tone = 'note', title } = Astro.props;
const bgMap = { note: 'var(--color-muted-light)', warning: 'var(--color-warning)', tip: 'var(--color-success)' };
---

<aside class={`callout callout-${tone}`} role="note">
	{title && <strong>{title}</strong>}
	<div class="callout-content"><slot /></div>
</aside>

<style>
	.callout { padding: var(--space-md); border-radius: var(--radius-sm); border: 1px solid var(--color-border); background: var(--color-surface); }
	.callout strong { display: block; margin-bottom: var(--space-xs); }
	.callout-note { border-left: 4px solid var(--color-accent); }
	.callout-warning { border-left: 4px solid var(--color-warning); }
	.callout-tip { border-left: 4px solid var(--color-success); }
	.callout-content { color: var(--color-text-secondary); }
</style>
